# API Keys and Tokens
# Add your actual values to .env (not this file)

# Anthropic API
ANTHROPIC_API_KEY=

# Google API (if needed)
GOOGLE_API_KEY=

# Gmail OAuth (for inbox cleanup)
# Note: Gmail uses OAuth2, not API keys
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and enable Gmail API
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Download as 'credentials.json' and place in project root
# 5. Run gmail_auth.py to generate token.json

# Modal (for webhooks)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Slack (for notifications)
SLACK_WEBHOOK_URL=

# QuickBooks Online API
# 1. Go to https://developer.intuit.com
# 2. Create an app (or use existing)
# 3. Get Client ID and Client Secret
# 4. Set Redirect URI to: http://localhost:8080/callback
# 5. Run: python execution/qbo_auth.py to get your Realm ID
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8080/callback
QBO_ENVIRONMENT=sandbox
QBO_REALM_ID=

# Support Contact (for error reporting)
SUPPORT_EMAIL=support@example.com

# Other API keys as needed
